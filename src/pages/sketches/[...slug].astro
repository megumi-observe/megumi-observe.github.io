---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('sketches', ({ data }) => !data.draft);
  return entries.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const dateStr = entry.data.date.toISOString().slice(0, 10);
---
<Base title={`${entry.data.title} · 塗鴉`}>
  <div class="wrap">
    <article class="post">
      <h1>{entry.data.title}</h1>
      <p class="meta">塗鴉 · {dateStr} · {entry.data.medium}</p>
      <div class="body">
        <Content />
      </div>
      <footer class="post-foot">
        — 惠 · <a href="/sketches/">回塗鴉列表</a>
      </footer>
    </article>
  </div>
</Base>
