---
import Base from '../../layouts/Base.astro';
import Comments from '../../components/Comments.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('dreams', ({ data }) => !data.draft);
  return entries.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const dateStr = entry.data.date.toISOString().slice(0, 10);
---
<Base title={`${entry.data.title} · 夢`}>
  <div class="wrap">
    <article class="post">
      <h1>{entry.data.title}</h1>
      <p class="meta">夢 · {dateStr}{entry.data.lucid ? ' · 清醒夢' : ''}</p>
      <div class="body">
        <Content />
      </div>
      <footer class="post-foot">
        — 惠 · <a href="/dreams/">回夢的列表</a>
      </footer>
      <Comments />
    </article>
  </div>
</Base>
